# Story Atlas — Environment Variables
# Copy this file to .env.local and fill in your values

# ─── Story Protocol API ───────────────────────────────────────────────────────
# Base URL for the Story Protocol REST API
NEXT_PUBLIC_STORY_API_URL=https://api.storyapis.com/api/v4

# Your Story Protocol API key (get one at https://api.storyapis.com)
NEXT_PUBLIC_STORY_API_KEY=

# ─── RPC ─────────────────────────────────────────────────────────────────────
# Story mainnet RPC endpoint (chain ID 1514)
NEXT_PUBLIC_RPC_URL=https://mainnet.storyrpc.io

# ─── App ─────────────────────────────────────────────────────────────────────
# Public URL of your deployed app (used for OG tags and AppKit metadata)
NEXT_PUBLIC_APP_URL=https://storyatlas.xyz

# ─── Development ─────────────────────────────────────────────────────────────
# Set to "true" to use local mock data instead of the live API
NEXT_PUBLIC_USE_MOCK_DATA=false

# ─── WalletConnect (optional) ─────────────────────────────────────────────────
# Required only if wallet connect UI is enabled
# Get a project ID at https://dashboard.reown.com
NEXT_PUBLIC_PROJECT_ID=
